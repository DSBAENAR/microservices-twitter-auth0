# Copy this file to .env (gitignored) and fill with YOUR Auth0 values.
# Load before running:  export $(grep -v '^#' .env | xargs)

# Your Auth0 tenant URL, with trailing slash
AUTH0_ISSUER_URI=https://YOUR-TENANT.us.auth0.com/

# The API identifier (Audience) configured in Auth0 Dashboard > APIs
AUTH0_AUDIENCE=https://twitter-api.YOUR-DOMAIN

# Comma-separated origins allowed by CORS (frontend URLs)
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://YOUR-S3-BUCKET.s3-website-us-east-1.amazonaws.com
