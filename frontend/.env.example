# Copy this file to .env (gitignored) and fill with YOUR Auth0 values.
# All VITE_* variables are EMBEDDED in the built bundle — never put secrets here.

# Auth0 SPA client (Applications > Single Page Application)
VITE_AUTH0_DOMAIN=YOUR-TENANT.us.auth0.com
VITE_AUTH0_CLIENT_ID=YOUR_SPA_CLIENT_ID

# Auth0 API identifier (Audience) — must match the backend
VITE_AUTH0_AUDIENCE=https://twitter-api.YOUR-DOMAIN

# Backend base URL (Spring Boot monolith or API Gateway invoke URL)
VITE_API_BASE_URL=http://localhost:8080
